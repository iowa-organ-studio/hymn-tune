
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
                 <!-- ***Title*** -->
        <title>Helft mir Gottes BWV 613</title>
      </titleStmt>
      <pubStmt>
        <respStmt><resp>Generated example</resp></respStmt>
      </pubStmt>
      <sourceDesc><p>Simple melody example</p></sourceDesc>
    </fileDesc>

    <!-- Work metadata (tags) -->
    <workDesc>
      <work>
                   <!-- ******Title******** -->
        <title>Helft mir Gottes BWV 613</title>

             <!-- ******Key (in lowercase) and Mode (in lowercase)****** -->
        <key pname="b" mode="minor"/>

             <!-- ******Duple or Triple (capitalized) *********-->
        <annot type="meterGroup">Triple</annot>

                    <!-- ******Collection *********-->
        <identifier type="collection">Orgelbuchlein</identifier>
      </work>
    </workDesc>
  </meiHead>

 <music>
    <body>
      <mdiv>
        <score>
           <scoreDef>
            <staffGrp>
              <staffDef n="1" lines="5">
                <clef shape="G" line="2"/>
                     <!-- ******Time signature *********-->
                <meterSig count="4" unit="4"/>
                     <!-- ******Key signature *********-->
                <keySig sig="2s"/>
                          <!-- ******Key  *********-->
                 <key pname="b" mode="minor"/>
              </staffDef>
            </staffGrp>
          </scoreDef>

     <section>
            <!-- Pickup -->
            <measure n="0" metcon="false">
              <staff n="1"><layer n="1">
                <note pname="b" oct="4" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="1">
              <staff n="1"><layer n="1">
                <note pname="b" oct="4" dur="4"/>
                <note pname="c" oct="5" dur="4"/>
                <note pname="d" oct="5" dur="4"/>
                <note pname="e" oct="5" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="2">
              <staff n="1"><layer n="1">
                <note pname="c" oct="5" dur="4" dots="1"/>
                <note pname="d" oct="5" dur="8"/>
                <note xml:id="m2e" pname="e" oct="5" dur="4"/>
                <note pname="f" oct="5" dur="4"/>
              </layer></staff>
              <fermata startid="#m2e" place="above"/>
            </measure>

            <measure n="3">
              <staff n="1"><layer n="1">
                <note pname="d" oct="5" dur="4"/>
                <note pname="b" oct="4" dur="4"/>
                <note pname="c" oct="5" dur="4"/>
                <note pname="c" oct="5" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="4">
              <staff n="1"><layer n="1">
                <note xml:id="m4b" pname="b" oct="4" dur="2" dots="1"/>
                <note pname="f" oct="5" dur="4"/>
              </layer></staff>
              <fermata startid="#m4b" place="above"/>
            </measure>

            <measure n="5">
              <staff n="1"><layer n="1">
                <note pname="e" oct="5" dur="4"/>
                <note pname="d" oct="5" dur="4"/>
                <note pname="c" oct="5" dur="4"/>
                <note pname="b" oct="4" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="6">
              <staff n="1"><layer n="1">
                <note xml:id="m6c1" pname="c" oct="5" dur="2" dots="1"/>
                <note pname="c" oct="5" dur="4"/>
              </layer></staff>
              <fermata startid="#m6c1" place="above"/>
            </measure>

            <measure n="7">
              <staff n="1"><layer n="1">
                <note pname="d" oct="5" dur="4"/>
                <note pname="e" oct="5" dur="4"/>
                <note pname="f" oct="5" dur="4"/>
                <note pname="d" oct="5" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="8">
              <staff n="1"><layer n="1">
                <note pname="e" oct="5" dur="4" dots="1"/>
                <note pname="d" oct="5" dur="8"/>
                <note xml:id="m8c" pname="c" oct="5" dur="4"/>
                <note pname="c" oct="5" dur="4"/>
              </layer></staff>
              <fermata startid="#m8c" place="above"/>
            </measure>

            <measure n="9">
              <staff n="1"><layer n="1">
                <note pname="d" oct="5" dur="4"/>
                <note pname="e" oct="5" dur="4"/>
                <note pname="f" oct="5" dur="4"/>
                <note pname="d" oct="5" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="10">
              <staff n="1"><layer n="1">
                <note pname="e" oct="5" dur="4" dots="1"/>
                <note pname="d" oct="5" dur="8"/>
                <note xml:id="m10c" pname="c" oct="5" dur="4"/>
                <note pname="g" oct="5" dur="4"/>
              </layer></staff>
              <fermata startid="#m10c" place="above"/>
            </measure>

            <measure n="11">
              <staff n="1"><layer n="1">
                <beam>
                  <note pname="d" oct="5" dur="8"/>
                  <note pname="c" oct="5" dur="8"/>
                </beam>
                <note pname="b" oct="4" dur="4"/>
                <note pname="c" oct="5" dur="4"/>
                <note pname="c" oct="5" dur="4"/>
              </layer></staff>
            </measure>

            <!-- Short final measure to balance pickup -->
            <measure n="12" metcon="false" right="dbl">
              <staff n="1"><layer n="1">
                <note xml:id="m12b" pname="b" oct="4" dur="2" dots="1"/>
              </layer></staff>
              <fermata startid="#m12b" place="above"/>
            </measure>

          </section>

        </score>
      </mdiv>
    </body>
  </music>

</mei>
