
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
                 <!-- ***Title*** -->
        <title>Leoni 372</title>
      </titleStmt>
      <pubStmt>
        <respStmt><resp>Generated example</resp></respStmt>
      </pubStmt>
      <sourceDesc><p>Simple melody example</p></sourceDesc>
    </fileDesc>

    <!-- Work metadata (tags) -->
    <workDesc>
      <work>
                   <!-- ******Title******** -->
        <title>Leoni 372</title>

             <!-- ******Key (in lowercase) and Mode (in lowercase)****** -->
        <key pname="f" mode="minor"/>

             <!-- ******Duple or Triple (capitalized) *********-->
        <annot type="meterGroup">Triple</annot>

                    <!-- ******Collection *********-->
        <identifier type="collection">Hymnal 1982</identifier>
      </work>
    </workDesc>
  </meiHead>

 <music>
    <body>
      <mdiv>
        <score>
           <scoreDef>
            <staffGrp>
              <staffDef n="1" lines="5">
                <clef shape="G" line="2"/>
                     <!-- ******Time signature *********-->
                <meterSig count="4" unit="4"/>
                     <!-- ******Key signature *********-->
                <keySig sig="4f"/>
                          <!-- ******Key  *********-->
                <key pname="f" accid="f" mode="minor"/>
              </staffDef>
            </staffGrp>
          </scoreDef>

  <section>
            <!-- Pickup -->
            <measure n="0" metcon="false">
              <staff n="1"><layer n="1">
                <note pname="c" oct="4" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="1">
              <staff n="1"><layer n="1">
                <note pname="f" oct="4" dur="4"/>
                <note pname="g" oct="4" dur="4"/>
                <note pname="a" oct="4" dur="4"/>
                <note pname="b" oct="4" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="2">
              <staff n="1"><layer n="1">
                <note pname="c" oct="5" dur="2" dots="1"/>
                <note pname="a" oct="4" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="3">
              <staff n="1"><layer n="1">
                <note pname="b" oct="4" dur="4"/>
                <note pname="c" oct="5" dur="4"/>
                <note pname="d" oct="5" dur="4"/>
                <note pname="e" oct="5" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="4">
              <staff n="1"><layer n="1">
                <note pname="c" oct="5" dur="2" dots="1"/>
                <note pname="g" oct="4" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="5">
              <staff n="1"><layer n="1">
                <note pname="a" oct="4" dur="4"/>
                <note pname="b" oct="4" dur="4"/>
                <note pname="c" oct="5" dur="4"/>
                <note pname="d" oct="5" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="6">
              <staff n="1"><layer n="1">
                <note pname="e" oct="5" dur="4"/>
                <note pname="g" oct="4" dur="4"/>
                <note pname="a" oct="4" dur="4"/>
                <note pname="d" oct="5" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="7">
              <staff n="1"><layer n="1">
                <note pname="c" oct="5" dur="2"/>
                <note pname="b" oct="4" dur="2"/>
              </layer></staff>
            </measure>

            <measure n="8">
              <staff n="1"><layer n="1">
                <note pname="a" oct="4" dur="2" dots="1"/>
                <note pname="a" oct="4" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="9">
              <staff n="1"><layer n="1">
                <note pname="c" oct="5" dur="4"/>
                <note pname="c" oct="5" dur="4"/>
                <note pname="c" oct="5" dur="4"/>
                <note pname="c" oct="5" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="10">
              <staff n="1"><layer n="1">
                <note pname="b" oct="4" dur="2" dots="1"/>
                <beam>
                  <note pname="a" oct="4" dur="8"/>
                  <note pname="g" oct="4" dur="8"/>
                </beam>
              </layer></staff>
            </measure>

            <measure n="11">
              <staff n="1"><layer n="1">
                <beam>
                  <note pname="f" oct="4" dur="8"/>
                  <note pname="g" oct="4" dur="8"/>
                  <note pname="a" oct="4" dur="8"/>
                  <note pname="b" oct="4" dur="8"/>
                </beam>
                <note pname="c" oct="5" dur="4"/>
                <note pname="f" oct="4" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="12">
              <staff n="1"><layer n="1">
                <note pname="f" oct="4" dur="4"/>
                <note pname="e" accid="n" oct="4" dur="2"/>
                <note pname="c" oct="4" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="13">
              <staff n="1"><layer n="1">
                <note pname="f" oct="4" dur="4"/>
                <note pname="g" oct="4" dur="4"/>
                <note pname="a" oct="4" dur="4"/>
                <note pname="b" oct="4" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="14">
              <staff n="1"><layer n="1">
                <note pname="c" oct="5" dur="4"/>
                <beam>
                  <note pname="b" oct="4" dur="8"/>
                  <note pname="c" oct="5" dur="8"/>
                </beam>
                <note pname="d" oct="5" dur="4"/>
                <beam>
                  <note pname="c" oct="5" dur="8"/>
                  <note pname="b" oct="4" dur="8"/>
                </beam>
              </layer></staff>
            </measure>

            <measure n="15">
              <staff n="1"><layer n="1">
                <note pname="a" oct="4" dur="2"/>
                <note pname="g" oct="4" dur="2"/>
              </layer></staff>
            </measure>

            <!-- Final shortened measure to balance pickup -->
            <measure n="16" metcon="false" right="dbl">
              <staff n="1"><layer n="1">
                <note pname="f" oct="4" dur="2" dots="1"/>
              </layer></staff>
            </measure>

          </section>

        </score>
      </mdiv>
    </body>
  </music>

</mei>

