
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
                 <!-- ***Title*** -->
        <title>Morgenglanz der Ewigkeit</title>
      </titleStmt>
    
    </fileDesc>

    <!-- Work metadata (tags) -->
    <workDesc>
      <work>
                   <!-- ******Title******** -->
        <title>Morgenglanz der Ewigkeit</title>

             <!-- ******Key (in lowercase) and Mode (in lowercase)****** -->
        <key pname="d" mode="major"/>

                             <!-- ******Collection *********-->
        <identifier type="collection">Senfter</identifier>
      </work>
    </workDesc>
  </meiHead>

 <music>
    <body>
      <mdiv>
        <score>
           <scoreDef>
            <staffGrp>
              <staffDef n="1" lines="5">
                <clef shape="G" line="2"/>
                     <!-- ******Time signature *********-->
                <meterSig count="4" unit="4"/>
                     <!-- ******Key signature *********-->
                <keySig sig="2s"/>
                          <!-- ******Key  *********-->
                <key pname="d" mode="major"/>
              </staffDef>
            </staffGrp>
          </scoreDef>



  <section>
            <!-- Volta repeat is linearized (no structural repeat encoding) -->

            <measure n="1">
              <staff n="1"><layer n="1">
                <note pname="f" oct="4" dur="4"/>
                <beam>
                  <note pname="e" oct="4" dur="8"/>
                  <note pname="d" oct="4" dur="8"/>
                </beam>
                <note pname="a" oct="4" dur="4"/>
                <note pname="b" oct="4" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="2">
              <staff n="1"><layer n="1">
                <note pname="g" oct="4" dur="4" dots="1"/>
                <note pname="f" oct="4" dur="8"/>
                <note pname="f" oct="4" dur="2"/>
              </layer></staff>
            </measure>

            <measure n="3">
              <staff n="1"><layer n="1">
                <note pname="d" oct="5" dur="4"/>
                <note pname="c" oct="5" dur="4"/>
                <note pname="b" oct="4" dur="4"/>
                <note pname="c" oct="5" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="4">
              <staff n="1"><layer n="1">
                <note pname="d" oct="5" dur="4"/>
                <note pname="c" oct="5" dur="4"/>
                <note pname="b" oct="4" dur="2"/>
              </layer></staff>
            </measure>

            <measure n="5" right="rptend">
  <staff n="1">
    <layer n="1">
      <note pname="a" oct="4" dur="1"/>
    </layer>
  </staff>
</measure>

            <measure n="6">
              <staff n="1"><layer n="1">
                <note pname="a" oct="4" dur="4"/>
                <note pname="a" oct="4" dur="4"/>
                <note pname="b" oct="4" dur="4"/>
                <note pname="a" oct="4" dur="4"/>
              </layer></staff>
            </measure>

            <measure n="7">
              <staff n="1"><layer n="1">
                <note pname="g" oct="4" dur="4"/>
                <note pname="f" oct="4" dur="4"/>
                <note pname="e" oct="4" dur="2"/>
              </layer></staff>
            </measure>

            <measure n="8">
              <staff n="1"><layer n="1">
                <note pname="f" oct="4" dur="2"/>
                <note pname="e" oct="4" dur="2"/>
              </layer></staff>
            </measure>

            <measure n="9" right="dbl">
              <staff n="1"><layer n="1">
                <note pname="d" oct="4" dur="1"/>
              </layer></staff>
            </measure>

          </section>



        </score>
      </mdiv>
    </body>
  </music>

</mei>
