
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
                 <!-- ***Title*** -->
        <title>Lob sei dem allmaechtigen Gott BWV 602</title>
      </titleStmt>
      <pubStmt>
        <respStmt><resp>Generated example</resp></respStmt>
      </pubStmt>
      <sourceDesc><p>Simple melody example</p></sourceDesc>
    </fileDesc>

    <!-- Work metadata (tags) -->
    <workDesc>
      <work>
                   <!-- ******Title******** -->
        <title>Lob sei dem allmaechtigen Gott BWV 602</title>

             <!-- ******Key (in lowercase) and Mode (in lowercase)****** -->
        <key pname="f" mode="major"/>

             <!-- ******Duple or Triple (capitalized) *********-->
        <annot type="meterGroup">Triple</annot>

                    <!-- ******Collection *********-->
        <identifier type="collection">Orgelbuchlein</identifier>
      </work>
    </workDesc>
  </meiHead>

 <music>
    <body>
      <mdiv>
        <score>
           <scoreDef>
            <staffGrp>
              <staffDef n="1" lines="5">
                <clef shape="G" line="2"/>
                     <!-- ******Time signature *********-->
                <meterSig count="4" unit="2"/>
                     <!-- ******Key signature *********-->
                <keySig sig="1f"/>
                          <!-- ******Key  *********-->
                 <key pname="f" mode="major"/>
              </staffDef>
            </staffGrp>
          </scoreDef>

      <section>
            <!-- Pickup -->
            <measure n="0" metcon="false">
              <staff n="1"><layer n="1">
                <note pname="a" oct="4" dur="2"/>
              </layer></staff>
            </measure>

            <measure n="1">
              <staff n="1"><layer n="1">
                <note pname="f" oct="4" dur="2"/>
                <note pname="a" oct="4" dur="2"/>
                <note pname="c" oct="5" dur="2"/>
                <note pname="d" oct="5" dur="2"/>
              </layer></staff>
            </measure>

            <measure n="2">
              <staff n="1"><layer n="1">
                <note pname="d" oct="5" dur="2"/>
                <note pname="b" oct="4" dur="2"/>
                <note xml:id="m2c" pname="c" oct="5" dur="2"/>
                <note pname="c" oct="5" dur="2"/>
              </layer></staff>
              <fermata startid="#m2c" place="above"/>
            </measure>

            <measure n="3">
              <staff n="1"><layer n="1">
                <note pname="d" oct="5" dur="2"/>
                <note pname="b" oct="4" dur="2"/>
                <note pname="c" oct="5" dur="2"/>
                <note pname="b" oct="4" dur="2"/>
              </layer></staff>
            </measure>

            <measure n="4">
              <staff n="1"><layer n="1">
                <note pname="a" oct="4" dur="2"/>
                <note pname="g" oct="4" dur="2"/>
                <note xml:id="m4a" pname="a" oct="4" dur="2"/>
                <note pname="c" oct="5" dur="2"/>
              </layer></staff>
              <fermata startid="#m4a" place="above"/>
            </measure>

            <measure n="5">
              <staff n="1"><layer n="1">
                <note pname="b" oct="4" dur="2"/>
                <note pname="g" oct="4" dur="2"/>
                <note pname="a" oct="4" dur="2"/>
                <note pname="b" oct="4" dur="2"/>
              </layer></staff>
            </measure>

            <measure n="6">
              <staff n="1"><layer n="1">
                <note pname="a" oct="4" dur="2"/>
                <note pname="c" oct="5" dur="2"/>
                <note xml:id="m6f" pname="f" oct="4" dur="2"/>
                <note pname="g" oct="4" dur="2"/>
              </layer></staff>
              <fermata startid="#m6f" place="above"/>
            </measure>

            <measure n="7">
              <staff n="1"><layer n="1">
                <note pname="a" oct="4" dur="2"/>
                <note pname="b" oct="4" dur="2"/>
                <note pname="c" oct="5" dur="2"/>
                <note pname="b" oct="4" dur="2"/>
              </layer></staff>
            </measure>

            <!-- Final shortened measure to balance pickup -->
            <measure n="8" metcon="false" right="dbl">
              <staff n="1"><layer n="1">
                <note pname="a" oct="4" dur="2"/>
                <note pname="g" oct="4" dur="2"/>
                <note xml:id="m8a" pname="a" oct="4" dur="2"/>
              </layer></staff>
              <fermata startid="#m8a" place="above"/>
            </measure>

          </section>

        </score>
      </mdiv>
    </body>
  </music>

